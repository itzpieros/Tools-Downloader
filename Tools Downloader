# ==============================================================================
# 5. LOGICA DEL BOTTONE DOWNLOAD
# ==============================================================================
$btnDownload.Add_Click({
    $selectedUrls = @()
    
    # Raccogli tutti gli elementi selezionati nelle varie schede
    foreach ($item in $script:checkedBoxesList) {
        $catName = $item.Category
        $box = $item.Control
        foreach ($checkedItem in $box.CheckedItems) {
            $url = $script:toolCategories[$catName][$checkedItem]
            $selectedUrls += @{ "Name" = $checkedItem; "URL" = $url }
        }
    }

    if ($selectedUrls.Count -eq 0) {
        [System.Windows.Forms.MessageBox]::Show("Seleziona almeno un tool prima di procedere!", "Attenzione", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Warning)
        return
    }

    $btnDownload.Enabled = $false
    $total = $selectedUrls.Count
    $current = 0

    foreach ($tool in $selectedUrls) {
        $current++
        $script:lblStatus.Text = "Status: Scaricando $($tool.Name) [$current/$total]..."
        [System.Windows.Forms.Application]::DoEvents() # Aggiorna la UI
        
        Download-File -url $tool.URL
    }

    $script:lblStatus.Text = "Status: Download Completato!"
    $script:lblStatus.ForeColor = [System.Drawing.Color]::LimeGreen
    [System.Windows.Forms.Application]::DoEvents()

    [System.Windows.Forms.MessageBox]::Show("Download completato con successo in:`n$script:folder", "Signal X", [System.Windows.Forms.MessageBoxButtons]::OK, [System.Windows.Forms.MessageBoxIcon]::Information)
    Start-Process explorer.exe $script:folder
    $form.Close()
})

